# Application
APP_ENV=development
APP_DEBUG=1
APP_DEFAULT_LANG=ru
# Базовый URL сайта. На проде: APP_ENV=production и APP_BASE_URL=https://ваш-домен (или не задавать, если прокси отдаёт X-Forwarded-Proto).
APP_BASE_URL=https://example.test/

# Analytics (опционально)
# YANDEX_METRIC_ID=12345678

# Photoroom API (опционально, нужен для /api/photoroom/remove-background)
# PHOTOROOM_API_KEY=
# PHOTOROOM_SANDBOX_API_KEY=
# PHOTOROOM_API_BASE_URL=https://image-api.photoroom.com
# PHOTOROOM_API_TIMEOUT=60
# PHOTOROOM_API_CONNECT_TIMEOUT=10
# PHOTOROOM_INTERNAL_TOKEN=change-me
